# ═══════════════════════════════════════════════════════
# PEHLI BAAR BACKEND — Environment Variables
# Copy this to .env and fill in real values
# ═══════════════════════════════════════════════════════

# ── Azure Document Intelligence ──────────────────────
# Endpoint for the Azure Document Intelligence resource
DOC_INTEL_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# API key (used in local dev; in prod, fetched from Key Vault)
DOC_INTEL_KEY=your-doc-intel-key-here

# ── Azure OpenAI ─────────────────────────────────────
# Endpoint for the Azure OpenAI resource
OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# API key (used in local dev; in prod, fetched from Key Vault)
OPENAI_KEY=your-openai-key-here
# Deployment name for GPT-4o model
OPENAI_DEPLOYMENT_NAME=gpt-4o

# ── Azure Speech Services ───────────────────────────
# Azure region where Speech resource is deployed
SPEECH_REGION=eastus
# API key (used in local dev; in prod, fetched from Key Vault)
SPEECH_KEY=your-speech-key-here

# ── Azure Blob Storage ──────────────────────────────
# Full connection string (used in local dev; in prod, fetched from Key Vault)
STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# Container names
STORAGE_CONTAINER_UPLOADS=uploads
STORAGE_CONTAINER_AUDIO=audio

# ── Azure Key Vault ─────────────────────────────────
# URI of the Key Vault instance (leave empty for local dev to use .env keys)
KEYVAULT_URI=https://your-vault.vault.azure.net/

# ── Azure Application Insights ──────────────────────
# Connection string for telemetry and error logging
APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;IngestionEndpoint=...

# ── Redis ────────────────────────────────────────────
# Connection URL for Redis session store
REDIS_URL=redis://localhost:6379

# ── Server ───────────────────────────────────────────
# Port the Express server listens on
PORT=3001
# Environment: development | production
NODE_ENV=development
# API key for x-api-key header authentication
API_KEY=local-dev-key-change-in-prod

# ── Limits ───────────────────────────────────────────
# Maximum upload file size in megabytes
MAX_FILE_SIZE_MB=10
# Session time-to-live in hours
SESSION_TTL_HOURS=2

# ── Twilio SMS Config ───────────────────────────────
# Twilio Account SID, Auth Token and Phone Number
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Google OAuth Config ─────────────────────────────
# Google OAuth 2.0 Client ID for frontend sign-in
GOOGLE_CLIENT_ID=
